# Copy this file to /opt/teampo/api.env on the EC2 instance and fill in the placeholders.
# Never commit the real /opt/teampo/api.env file.

SPRING_PROFILES_ACTIVE=deploy

SPRING_DATASOURCE_URL=jdbc:mysql://<rds-endpoint>:3306/teampo?serverTimezone=UTC&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=teampoadmin
SPRING_DATASOURCE_PASSWORD=<rds-password>

SPRING_DATA_REDIS_HOST=teampo-redis
SPRING_DATA_REDIS_PORT=6379

JWT_SECRET=<base64-jwt-secret>
JWT_ACCESS_TOKEN_EXPIRATION=30m
JWT_REFRESH_TOKEN_EXPIRATION=14d

S3_BUCKET=teampo-dev-56e79e9d-profile-images
S3_DIR=images
S3_PATH_STYLE_ACCESS_ENABLED=false

AWS_REGION=ap-northeast-2
SERVER_PORT=8080
APP_LOG_LEVEL=info
