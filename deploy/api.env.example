# Copy this file to /opt/teampo/api.env on the EC2 instance and fill in the placeholders.
# Never commit the real /opt/teampo/api.env file.

SPRING_PROFILES_ACTIVE=production

SPRING_DATASOURCE_URL=jdbc:mysql://<rds-endpoint>:3306/teampo?serverTimezone=UTC&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=teampoadmin
SPRING_DATASOURCE_PASSWORD=<rds-password>

SPRING_DATA_REDIS_HOST=teampo-redis
SPRING_DATA_REDIS_PORT=6379

JWT_SECRET=<base64-jwt-secret>
JWT_ACCESS_TOKEN_EXPIRATION=30m
JWT_REFRESH_TOKEN_EXPIRATION=14d
GITHUB_OAUTH_TOKEN_ENCRYPTION_SECRET=<base64-github-token-encryption-secret>

S3_BUCKET=teampo-dev-56e79e9d-profile-images
S3_DIR=images
S3_PATH_STYLE_ACCESS_ENABLED=false

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=<smtp-username>
MAIL_PASSWORD=<smtp-password>
MAIL_AUTH_CODE_TTL=PT5M
MAIL_VERIFIED_TTL=PT10M
MAIL_AUTH_CODE_SUBJECT=TeamPo 이메일 인증번호

GITHUB_CLIENT_ID=GithubApp Client ID
GITHUB_CLIENT_SECRET=GithubApp Secret 값
GITHUB_REDIRECT_URI=GithubApp Redirect URI
GITHUB_OAUTH_SUCCESS_REDIRECT_URI=Github OAuth SUCCESS_REDIRECT_URI
GITHUB_OAUTH_AUTHORIZATION_CODE_TTL=PT3M
GITHUB_OAUTH_REST_CLIENT_CONNECT_TIMEOUT=PT3S
GITHUB_OAUTH_REST_CLIENT_READ_TIMEOUT=PT5S

AWS_REGION=ap-northeast-2
SERVER_PORT=8080
APP_LOG_LEVEL=info
